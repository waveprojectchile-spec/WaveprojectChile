# =========================================
# Wave Project GYM — Variables de entorno
# =========================================
# Copiá este archivo como .env.local y completá los valores reales.
# NUNCA subas .env.local a git (ya está en .gitignore).

# ----- Supabase -----
# Panel: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----- MercadoPago -----
# Panel: https://www.mercadopago.cl/developers/panel/app
# Podés arrancar con el Access Token de TEST y después pasar a PROD.
MP_ACCESS_TOKEN=TEST-xxxxxxxx

# ----- Resend (emails) -----
# Panel: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# ----- URL base -----
# Para desarrollo local. En producción Vercel usa la URL del deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
